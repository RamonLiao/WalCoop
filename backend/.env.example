# Backend secrets — NEVER commit the filled .env. This is server-side only.
SUI_NETWORK=testnet

# Tatum gateway (key stays server-side, unlike the frontend bundle).
TATUM_API_KEY=
# TATUM_RPC_URL=https://sui-testnet.gateway.tatum.io/

DATA_COOP_PACKAGE_ID=0xb83403fe50e856b02c4b844cb9cc0cf2a8fe822161fdaf6619ae259fc0c8f286

# Backend signer (also the model-provider for settlement). Needs testnet SUI + WAL.
SUI_PRIVATE_KEY=suiprivkey1...

# ProviderCap bound to the backend address (admin grants it via the dApp/Move).
PROVIDER_CAP_ID=

# For `npm run e2e` only: the deployer's PublisherCap (the e2e script grants
# itself a ProviderCap from it). From docs/deployment.md.
PUBLISHER_CAP_ID=0x68116443a48120b0b040a3763a897dfc28ff65e0b5f7ed11ab8d09acbde45bd6

# Seal (defaults to Mysten testnet open-mode key servers, threshold 2).
# SEAL_KEY_SERVERS=0x...,0x...
SEAL_THRESHOLD=2
WALRUS_EPOCHS=3
PORT=8787
