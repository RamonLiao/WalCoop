# Copy to .env.local and fill after deployment.
VITE_DATA_COOP_PACKAGE_ID=0x0
VITE_SUI_NETWORK=testnet
# Tatum gateway API key (https://dashboard.tatum.io). Routes Sui gRPC through
# Tatum. Leave blank to use the public fullnode. NOTE: shipped in the client
# bundle — use a testnet key, or proxy via a backend for production.
VITE_TATUM_API_KEY=
